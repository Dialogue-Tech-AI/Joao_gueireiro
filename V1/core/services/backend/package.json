{
  "name": "altese-autopecas",
  "version": "1.0.0",
  "description": "Sistema de atendimento híbrido IA + Humano para Altese Autopeças",
  "main": "dist/main.js",
  "scripts": {
    "dev": "cross-env NODE_PATH=./node_modules ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "migration:generate": "typeorm migration:generate",
    "migration:run": "ts-node scripts/db/run-migrations.ts",
    "migration:revert": "typeorm migration:revert",
    "seed:run": "cross-env NODE_PATH=./node_modules ts-node --project tsconfig.seed.json scripts/seed/index.ts",
    "seed:processes": "cross-env NODE_PATH=./node_modules ts-node --project tsconfig.seed.json ../../shared/database/seed/seed-processes.ts",
    "cleanup:users": "ts-node scripts/db/cleanup-orphaned-users.ts",
    "docker:up": "docker compose -f ../../../config/local/dependencies/docker-compose.yml up -d",
    "docker:down": "docker compose -f ../../../config/local/dependencies/docker-compose.yml down",
    "docker:logs": "docker compose -f ../../../config/local/dependencies/docker-compose.yml logs -f",
    "docker:prod": "docker compose -f ../../../config/server/dependencies/docker-compose.yml up -d",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "keywords": [
    "whatsapp",
    "chat",
    "ai",
    "crm",
    "customer-service"
  ],
  "author": "Altese Autopeças",
  "license": "PROPRIETARY",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/client-sqs": "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.995.0",
    "@hapi/boom": "^10.0.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "amqplib": "^0.10.3",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "minio": "^7.1.3",
    "multer": "^2.0.2",
    "openai": "^4.20.1",
    "pg": "^8.11.3",
    "pino": "^10.2.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "reflect-metadata": "^0.1.13",
    "sharp": "^0.33.5",
    "socket.io": "^4.6.0",
    "typeorm": "^0.3.28",
    "uuid": "^9.0.1",
    "whatsapp-web.js": "^1.34.4",
    "winston": "^3.11.0",
    "winston-transport": "^4.9.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.4",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.10",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.4",
    "@types/pino": "^7.0.4",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
