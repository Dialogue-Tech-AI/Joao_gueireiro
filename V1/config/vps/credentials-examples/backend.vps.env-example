# ============================================================
# Backend - Variaveis de ambiente (VPS) - EXEMPLO
# ============================================================
# Copie para backend.vps.env e preencha os valores marcados.
# cp backend.vps.env-example backend.vps.env
# ============================================================

IS_PRODUCTION=false

APP_PORT_DEV=3000
APP_NAME_DEV=Altese Autopeças

DB_HOST_DEV=postgres
DB_PORT_DEV=5432
DB_USER_DEV=guerreiros
DB_PASSWORD_DEV=guerreiros123
DB_NAME_DEV=guerreiros
DB_SYNC_DEV=false
DB_LOGGING_DEV=false
DB_SSL_DEV=false

REDIS_HOST_DEV=redis
REDIS_PORT_DEV=6379
REDIS_PASSWORD_DEV=
REDIS_DB_DEV=0

RABBITMQ_HOST_DEV=rabbitmq
RABBITMQ_PORT_DEV=5672
RABBITMQ_USER_DEV=guerreiros
RABBITMQ_PASS_DEV=guerreiros123
RABBITMQ_VHOST_DEV=/
RABBITMQ_QUEUE_MESSAGES_DEV=guerreiros-messages
RABBITMQ_QUEUE_AI_DEV=guerreiros-ai-requests
RABBITMQ_QUEUE_NOTIFICATIONS_DEV=guerreiros-notifications

MINIO_ENDPOINT_DEV=minio
MINIO_PORT_DEV=9000
MINIO_USE_SSL_DEV=false
MINIO_ACCESS_KEY_DEV=guerreiros
MINIO_SECRET_KEY_DEV=guerreiros
MINIO_BUCKET_ATTACHMENTS_DEV=attachments
MINIO_BUCKET_MEDIA_DEV=media
MINIO_BUCKET_LOGS_DEV=logs

# >>> PREENCHA <<<
JWT_SECRET_DEV=TROQUE_POR_UM_SECRET_SEGURO
JWT_EXPIRES_IN_DEV=1d
JWT_REFRESH_EXPIRES_IN_DEV=7d

# >>> PREENCHA <<<
OPENAI_API_KEY_DEV=sk-proj-SUA_CHAVE_AQUI
OPENAI_TEMPERATURE_DEV=0.7
OPENAI_MAX_TOKENS_DEV=1000
OPENAI_TIMEOUT_DEV=30000

INTERNAL_API_KEY_DEV=internal-key-dev
QDRANT_PORT_DEV=6333

# >>> PREENCHA <<<
WHATSAPP_META_ACCESS_TOKEN_DEV=SEU_TOKEN_AQUI
WHATSAPP_META_VERIFY_TOKEN_DEV=123456
WHATSAPP_UNOFFICIAL_SESSION_PATH=./sessions

# >>> TROQUE PELO SEU DOMINIO <<<
CORS_ORIGIN_DEV=https://seudominio.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

LOG_LEVEL=info
LOG_FORMAT=json

ATTENDANCE_INACTIVE_TIMEOUT=86400000
ATTENDANCE_CONTEXT_RETENTION_DAYS=7
AI_CONTEXT_TTL=604800
ROUTING_STRATEGY=round-robin
AFFINITY_RETENTION_DAYS=90
