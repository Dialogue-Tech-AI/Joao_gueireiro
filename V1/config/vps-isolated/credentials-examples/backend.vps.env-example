# ============================================================
# Backend — VPS (copiar para credentials/backend.vps.env)
# ============================================================
# Alinhado a docker-compose.vps.yml e ao compose local (joao_guerreiro).
# ============================================================

IS_PRODUCTION=true

APP_PORT_DEV=3000
APP_NAME_DEV=Joao Guerreiro

DB_HOST_DEV=postgres
DB_PORT_DEV=5432
DB_USER_DEV=joao_guerreiro
DB_PASSWORD_DEV=joao_guerreiro123
DB_NAME_DEV=joao_guerreiro
DB_SYNC_DEV=false
DB_LOGGING_DEV=false
DB_SSL_DEV=false

REDIS_HOST_DEV=redis
REDIS_PORT_DEV=6379
REDIS_PASSWORD_DEV=
REDIS_DB_DEV=0

RABBITMQ_HOST_DEV=rabbitmq
RABBITMQ_PORT_DEV=5672
RABBITMQ_USER_DEV=joao_guerreiro
RABBITMQ_PASS_DEV=joao_guerreiro123
RABBITMQ_VHOST_DEV=/
RABBITMQ_QUEUE_MESSAGES_DEV=joao_guerreiro-messages
RABBITMQ_QUEUE_AI_DEV=joao_guerreiro-ai-requests
RABBITMQ_QUEUE_NOTIFICATIONS_DEV=joao_guerreiro-notifications

MINIO_ENDPOINT_DEV=minio
MINIO_PORT_DEV=9000
MINIO_USE_SSL_DEV=false
MINIO_ACCESS_KEY_DEV=joao_guerreiro
MINIO_SECRET_KEY_DEV=joao_guerreiro
MINIO_BUCKET_ATTACHMENTS_DEV=attachments
MINIO_BUCKET_MEDIA_DEV=media
MINIO_BUCKET_LOGS_DEV=logs

JWT_SECRET_DEV=TROQUE_POR_SECRET_LONGO_E_UNICO
JWT_EXPIRES_IN_DEV=1d
JWT_REFRESH_EXPIRES_IN_DEV=7d

OPENAI_API_KEY_DEV=sk-proj-SUA_CHAVE
OPENAI_TEMPERATURE_DEV=0.7
OPENAI_MAX_TOKENS_DEV=1000
OPENAI_TIMEOUT_DEV=30000

INTERNAL_API_KEY_DEV=internal-key-joao-guerreiro-vps
QDRANT_PORT_DEV=6333

WHATSAPP_META_ACCESS_TOKEN_DEV=
WHATSAPP_META_VERIFY_TOKEN_DEV=
WHATSAPP_UNOFFICIAL_SESSION_PATH=./sessions

CORS_ORIGIN_DEV=https://seudominio.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

LOG_LEVEL=info
LOG_FORMAT=json

ATTENDANCE_INACTIVE_TIMEOUT=86400000
ATTENDANCE_CONTEXT_RETENTION_DAYS=7
AI_CONTEXT_TTL=604800
ROUTING_STRATEGY=round-robin
AFFINITY_RETENTION_DAYS=90
