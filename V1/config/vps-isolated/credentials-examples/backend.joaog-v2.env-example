# ============================================================
# Backend — instância isolada joaog-v2 (copiar para credentials/backend.joaog-v2.env)
# ============================================================
# Valores abaixo devem coincidir com docker-compose.joaog-v2.yml (Postgres, RabbitMQ, MinIO).
# Filas RabbitMQ com prefixo próprio evitam consumo cruzado com outra stack.
# ============================================================

IS_PRODUCTION=true

APP_PORT_DEV=3000
APP_NAME_DEV=Joao Guerreiro

DB_HOST_DEV=postgres
DB_PORT_DEV=5432
DB_USER_DEV=joaog_v2
DB_PASSWORD_DEV=TROQUE_DB_PASSWORD_IGUAL_AO_COMPOSE
DB_NAME_DEV=joaog_v2
DB_SYNC_DEV=false
DB_LOGGING_DEV=false
DB_SSL_DEV=false

REDIS_HOST_DEV=redis
REDIS_PORT_DEV=6379
REDIS_PASSWORD_DEV=
REDIS_DB_DEV=0

RABBITMQ_HOST_DEV=rabbitmq
RABBITMQ_PORT_DEV=5672
RABBITMQ_USER_DEV=joaog_v2
RABBITMQ_PASS_DEV=TROQUE_RABBIT_PASSWORD_IGUAL_AO_COMPOSE
RABBITMQ_VHOST_DEV=/
RABBITMQ_QUEUE_MESSAGES_DEV=joaog-v2-messages
RABBITMQ_QUEUE_AI_DEV=joaog-v2-ai-requests
RABBITMQ_QUEUE_NOTIFICATIONS_DEV=joaog-v2-notifications

MINIO_ENDPOINT_DEV=minio
MINIO_PORT_DEV=9000
MINIO_USE_SSL_DEV=false
MINIO_ACCESS_KEY_DEV=joaog_v2
MINIO_SECRET_KEY_DEV=TROQUE_MINIO_PASSWORD_IGUAL_AO_COMPOSE
MINIO_BUCKET_ATTACHMENTS_DEV=attachments
MINIO_BUCKET_MEDIA_DEV=media
MINIO_BUCKET_LOGS_DEV=logs

JWT_SECRET_DEV=TROQUE_POR_SECRET_LONGO_E_UNICO
JWT_EXPIRES_IN_DEV=1d
JWT_REFRESH_EXPIRES_IN_DEV=7d

OPENAI_API_KEY_DEV=sk-proj-SUA_CHAVE
OPENAI_TEMPERATURE_DEV=0.7
OPENAI_MAX_TOKENS_DEV=1000
OPENAI_TIMEOUT_DEV=30000

INTERNAL_API_KEY_DEV=internal-key-joaog-v2-UNICO
QDRANT_PORT_DEV=6333

WHATSAPP_META_ACCESS_TOKEN_DEV=
WHATSAPP_META_VERIFY_TOKEN_DEV=
WHATSAPP_UNOFFICIAL_SESSION_PATH=./sessions

# URL pública do novo subdomínio (HTTPS)
CORS_ORIGIN_DEV=https://novo.subdominio.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

LOG_LEVEL=info
LOG_FORMAT=json

ATTENDANCE_INACTIVE_TIMEOUT=86400000
ATTENDANCE_CONTEXT_RETENTION_DAYS=7
AI_CONTEXT_TTL=604800
ROUTING_STRATEGY=round-robin
AFFINITY_RETENTION_DAYS=90
