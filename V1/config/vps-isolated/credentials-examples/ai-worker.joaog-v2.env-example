RABBITMQ_URL=amqp://joaog_v2:TROQUE_RABBIT_PASSWORD_IGUAL_AO_COMPOSE@rabbitmq:5672/
POSTGRES_URL=postgresql://joaog_v2:TROQUE_DB_PASSWORD_IGUAL_AO_COMPOSE@postgres:5432/joaog_v2

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

QDRANT_HOST=qdrant
QDRANT_PORT=6333

OPENAI_API_KEY=sk-proj-SUA_CHAVE
OPENAI_MODEL=gpt-4o-mini

NODE_API_URL=http://app:3000
INTERNAL_API_KEY=internal-key-joaog-v2-UNICO

USD_BRL_RATE=5.5
USE_SQS=false
LOG_LEVEL=INFO
