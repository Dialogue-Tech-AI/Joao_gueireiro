# ============================================================
# AI Worker — VPS (copiar para credentials/ai-worker.vps.env)
# ============================================================
# Senhas abaixo devem coincidir com config/vps-isolated/.env (POSTGRES_PASSWORD,
# RABBITMQ_PASSWORD) e com credentials/backend.vps.env (INTERNAL_API_KEY = INTERNAL_API_KEY_DEV).

# Host tem de ser rabbitmq/postgres (nomes do compose), nunca localhost — dentro do contentor localhost não é o broker/DB.
RABBITMQ_URL=amqp://joao_guerreiro:joao_guerreiro123@rabbitmq:5672/
POSTGRES_URL=postgresql://joao_guerreiro:joao_guerreiro123@postgres:5432/joao_guerreiro

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Obrigatório — chave real OpenAI (sk-...)
OPENAI_API_KEY=sk-proj-SUA_CHAVE
OPENAI_MODEL=gpt-4o-mini

NODE_API_URL=http://app:3000
# Obrigatório — igual a INTERNAL_API_KEY_DEV no backend.vps.env
INTERNAL_API_KEY=internal-key-joao-guerreiro-vps

USD_BRL_RATE=5.5
USE_SQS=false
LOG_LEVEL=INFO
